# Daytona API Key (get from https://app.daytona.io or run 'daytona login')
DAYTONA_API_KEY=

# E2B API Key (get from https://e2b.dev)
E2B_API_KEY=

# Docker image (used by build-image.ts / make image)
# IMAGE_TAG: optional; if unset, uses root package.json "version"
IMAGE_NAME=vikadata/sandagent
# IMAGE_TAG=0.1.0
