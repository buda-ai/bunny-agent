# ====================================
# SandAgent Environment Variables
# ====================================
# Copy this file to .env and fill in your API keys

# ====================================
# Claude Runner (--runner claude)
# ====================================

# Required: Anthropic API Key for Claude Agent SDK
# Get from: https://console.anthropic.com/settings/keys
# Or set a dummy value if using proxy authentication
ANTHROPIC_API_KEY=

# Optional: Custom Anthropic API Base URL (for proxies or third-party services)
# Example: https://api.openai-proxy.com/v1
ANTHROPIC_BASE_URL=

# Optional: Anthropic Auth Token (for LiteLLM/gateway proxies)
# Use with ANTHROPIC_BASE_URL or ANTHROPIC_BEDROCK_BASE_URL
ANTHROPIC_AUTH_TOKEN=

# Optional: LiteLLM Master Key (alternative to ANTHROPIC_AUTH_TOKEN)
LITELLM_MASTER_KEY=

# Optional: AWS Bedrock Configuration
# Bedrock Base URL (for Bedrock proxy)
ANTHROPIC_BEDROCK_BASE_URL=
# Set to 1 to enable Bedrock pass-through mode
CLAUDE_CODE_USE_BEDROCK=
# AWS Bearer Token for Bedrock
AWS_BEARER_TOKEN_BEDROCK=

# Optional: Disable experimental beta features (required for some LiteLLM proxies)
# Set to 1 if your proxy returns "invalid beta flag" errors
CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=

# ====================================
# Pi Runner (--runner pi)
# ====================================
# Pi runner supports multiple LLM providers

# Google Gemini
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GOOGLE_GEMINI_BASE_URL="https://llm.bika.ltd/gemini"
GOOGLE_API_KEY=

# OpenAI
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (for Pi runner)
# Get from: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY= (same as above)

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# GitHub Copilot (OAuth)
# Requires GitHub Copilot subscription
# GITHUB_TOKEN=

# ====================================
# Gemini Runner (--runner gemini)
# ====================================
# Required: Gemini API key
# Preferred variable: GEMINI_API_KEY
# Optional alias accepted by some setups: GOOGLE_API_KEY
#
# Required for proxy/custom endpoint:
# Gemini CLI reads GOOGLE_GEMINI_BASE_URL
# (SandAgent also maps GEMINI_BASE_URL -> GOOGLE_GEMINI_BASE_URL for compatibility)
#
# Important:
# Even with correct key/base URL, model can still return 404 if your provider
# or account does not expose that model name.
# Example that worked in local verification: gemini-2.5-flash
# Example that returned 404 in local verification: gemini-3-flash
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GOOGLE_GEMINI_BASE_URL=
# GEMINI_BASE_URL=

# ====================================
# Sandbox Providers
# ====================================

# Optional: E2B Cloud Sandbox (recommended for production)
# Get from: https://e2b.dev/dashboard
E2B_API_KEY=

# Optional: Sandock Cloud Sandbox (Docker-based alternative)
# Get from: https://sandock.io
SANDOCK_API_KEY=

# Optional: Daytona Workspace Sandbox
# Get from: https://app.daytona.io or run 'daytona login'
DAYTONA_API_KEY=
