{
  "$schema": "https://modelcontextprotocol.io/schemas/mcp.json",
  "description": "SEO Keywords Analytics Agent MCP configuration with Google Search Console and filesystem access",
  "servers": {
    "gsc": {
      "command": "npx",
      "args": ["-y", "mcp-server-gsc"],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "/Users/qikun/sandagent/templates/seo-keywords-analytics/gsc-credentials.json"
      }
    },
    "filesystem": {
      "command": "mcp-server-filesystem",
      "args": ["/workspace"]
    }
  }
}