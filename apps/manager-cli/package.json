{
  "name": "@bunny-agent/manager-cli",
  "version": "0.6.2",
  "description": "BunnyAgent Manager CLI - Manage sandboxes, run agents with templates, and control sessions from the command line",
  "type": "module",
  "bin": {
    "bunny-agent-manager": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'",
    "test": "vitest run --passWithNoTests"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vikadata/bunny-agent.git",
    "directory": "apps/manager-cli"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@bunny-agent/manager": "workspace:*",
    "@bunny-agent/sandbox-e2b": "workspace:*",
    "@bunny-agent/sandbox-sandock": "workspace:*",
    "@bunny-agent/runner-claude": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  }
}
