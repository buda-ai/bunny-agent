# E2B API Key (get from https://e2b.dev)
E2B_API_KEY=e2b_xxx

# Daytona API Key (get from https://app.daytona.io)
DAYTONA_API_KEY=dtn_xxx

# Choose ONE of the following:

# Option 1: Anthropic API Key (direct)
# ANTHROPIC_API_KEY=sk-ant-xxx

# Option 2: AWS Bedrock (set both)
AWS_BEARER_TOKEN_BEDROCK=xxx
# CLAUDE_CODE_USE_BEDROCK=1 is auto-set when AWS_BEARER_TOKEN_BEDROCK is provided
