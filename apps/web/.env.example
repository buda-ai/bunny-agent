# Example chat + /api/ai — copy to `.env.local` in this directory (`apps/web`).
# Next.js loads env files from `apps/web` when you run `pnpm dev` here.

# Required for E2B sandbox (example app default).
E2B_API_KEY=

# Sandock + vikadata/sandagent: optional second arg to `sleep` inside the image
# entrypoint (default `infinity`, same as Dockerfile CMD). Use e.g. 1800 for a fixed TTL.
# SANDOCK_CONTAINER_SLEEP_SEC=1800
