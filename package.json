{
  "name": "sandagent",
  "version": "0.1.4",
  "private": true,
  "description": "Sandboxed Super Agent runtime that speaks AI SDK UI natively",
  "repository": {
    "type": "git",
    "url": "https://github.com/vikadata/sandagent.git"
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
