{
  "name": "@sandagent/runner-core",
  "version": "0.1.0",
  "private": true,
  "description": "Shared runner dispatch logic for runner-cli and sandagent-daemon",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@sandagent/runner-claude": "workspace:*",
    "@sandagent/runner-codex": "workspace:*",
    "@sandagent/runner-gemini": "workspace:*",
    "@sandagent/runner-opencode": "workspace:*",
    "@sandagent/runner-pi": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  }
}
