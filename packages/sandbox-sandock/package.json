{
  "name": "@sandagent/sandbox-sandock",
  "version": "0.9.0",
  "description": "Sandock sandbox adapter for SandAgent",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'",
    "test": "vitest run --passWithNoTests"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vikadata/sandagent.git",
    "directory": "packages/sandbox-sandock"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@sandagent/manager": "workspace:*",
    "sandock": "^2.2.6"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  }
}
