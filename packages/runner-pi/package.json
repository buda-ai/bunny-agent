{
  "name": "@bunny-agent/runner-pi",
  "version": "0.6.4-beta.0",
  "private": true,
  "description": "Pi agent runtime for BunnyAgent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "copy-assets": "node -e \"const fs=require('fs'),path=require('path');for(const d of ['agents','prompts']){const src=path.join('src/extensions/subagent',d);const dst=path.join('dist/extensions/subagent',d);fs.mkdirSync(dst,{recursive:true});for(const f of fs.readdirSync(src))if(f.endsWith('.md'))fs.copyFileSync(path.join(src,f),path.join(dst,f));}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.74.0",
    "@earendil-works/pi-ai": "0.74.0",
    "@earendil-works/pi-coding-agent": "0.74.0",
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^1.6.1"
  },
  "keywords": [
    "bunny-agent",
    "pi",
    "agent",
    "runner"
  ],
  "author": "BunnyAgent",
  "license": "Apache-2.0"
}
