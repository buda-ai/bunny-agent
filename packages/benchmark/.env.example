# ====================================
# SandAgent Benchmark Environment Variables
# ====================================
# Copy this file to .env and fill in your API keys
# These keys enable non-interactive authentication for CLI tools

# Hugging Face Token for dataset access
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# For claudecode (Claude Code CLI)
# Get from: https://console.anthropic.com/settings/keys
# The CLI will use this automatically for non-interactive authentication
ANTHROPIC_API_KEY=

# For codex-cli (OpenAI Codex CLI)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# For gemini-cli (Google Gemini CLI)
# Option 1: Using Gemini API Key (AI Studio)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Option 2: Using Vertex AI with Google Cloud
GOOGLE_API_KEY=
# Set to `true` when using `GOOGLE_API_KEY` for Vertex AI
# GOOGLE_GENAI_USE_VERTEXAI=true