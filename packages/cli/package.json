{
  "name": "@sandagent/cli",
  "version": "0.1.0",
  "description": "SandAgent CLI - Agent runner that streams AI SDK UI messages",
  "type": "module",
  "bin": {
    "sandagent": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vikadata/sandagent.git",
    "directory": "packages/cli"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@sandagent/runner-claude": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
