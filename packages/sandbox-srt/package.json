{
  "name": "@bunny-agent/sandbox-srt",
  "version": "0.9.51-release.1",
  "description": "Locally-isolated sandbox adapter for BunnyAgent — wraps commands with Anthropic's sandbox runtime (srt)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'",
    "test": "vitest run --passWithNoTests"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vikadata/bunny-agent.git",
    "directory": "packages/sandbox-srt"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "keywords": [
    "sandbox",
    "srt",
    "isolation",
    "bubblewrap",
    "seatbelt",
    "bunny-agent",
    "adapter"
  ],
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.65",
    "@bunny-agent/manager": "workspace:*",
    "@bunny-agent/sandbox-local": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  }
}
