{
  "name": "@sandagent/ui",
  "version": "0.1.2-beta.3",
  "description": "SandAgent UI components - Ready-to-use React components for building AI chat interfaces",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./styles.css": "./src/styles.css",
    "./chat": {
      "import": "./src/components/chat/index.ts",
      "types": "./src/components/chat/index.ts"
    },
    "./tools": {
      "import": "./src/components/tools/index.ts",
      "types": "./src/components/tools/index.ts"
    },
    "./artifacts": {
      "import": "./src/components/artifacts/index.ts",
      "types": "./src/components/artifacts/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./styles.css": "./dist/styles.css",
      "./chat": {
        "import": "./dist/chat/index.js",
        "types": "./dist/chat/index.d.ts"
      },
      "./tools": {
        "import": "./dist/tools/index.js",
        "types": "./dist/tools/index.d.ts"
      },
      "./artifacts": {
        "import": "./dist/artifacts/index.js",
        "types": "./dist/artifacts/index.d.ts"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome format . --write && biome check . --write",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "sandagent",
    "ui",
    "react",
    "ai",
    "chat",
    "components"
  ],
  "license": "Apache-2.0",
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.3",
    "ai": "^6.0.19",
    "clsx": "^2.1.1",
    "kui": "workspace:*",
    "lucide-react": "^0.556.0",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
