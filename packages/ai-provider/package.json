{
  "name": "@sandagent/ai-provider",
  "version": "0.1.0-beta.1",
  "description": "AI SDK provider for SandAgent - run Claude Agent SDK in isolated sandboxes",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'",
    "test": "vitest run --passWithNoTests"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vikadata/sandagent.git",
    "directory": "packages/ai-provider"
  },
  "keywords": [
    "ai-sdk",
    "vercel-ai",
    "ai-provider",
    "claude",
    "anthropic",
    "sandbox",
    "sandagent"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@sandagent/manager": "workspace:*",
    "@ai-sdk/provider": "^3.0.0",
    "@ai-sdk/provider-utils": "^2.2.8"
  },
  "peerDependencies": {
    "ai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sandagent/sandbox-local": "workspace:*",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  }
}
