    "@e2b/code-interpreter": ">=0.0.5"
  },
  "peerDependenciesMeta": {
    "@e2b/code-interpreter": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
