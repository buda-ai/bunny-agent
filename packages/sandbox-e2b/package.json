  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vikadata/sandagent.git",
    "directory": "packages/sandbox-e2b"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@sandagent/core": "workspace:*"
  },
