{
  "name": "@sandagent/benchmark-cli",
  "version": "0.1.1",
  "private": true,
  "description": "GAIA benchmark runner for comparing agent CLIs (gemini-cli, claudecode, codex-cli, sandagent)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sandagent-benchmark": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'",
    "test": "vitest run --passWithNoTests",
    "benchmark": "tsx src/cli.ts",
    "benchmark:download": "tsx src/cli.ts download",
    "benchmark:run": "tsx src/cli.ts run",
    "benchmark:compare": "tsx src/cli.ts compare",
    "benchmark:level1": "tsx src/cli.ts run --level 1",
    "benchmark:level2": "tsx src/cli.ts run --level 2",
    "benchmark:level3": "tsx src/cli.ts run --level 3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vikadata/sandagent.git",
    "directory": "packages/benchmark"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@huggingface/hub": "^2.6.12",
    "dotenv": "^16.3.1",
    "hyparquet": "^1.20.2",
    "mime-types": "^2.1.35"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  }
}
