{
  "$schema": "https://biomejs.dev/schemas/2.3.10/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "useTemplate": "off",
        "noUnusedTemplateLiteral": "off",
        "useNodejsImportProtocol": "off"
      },
      "suspicious": {
        "noImplicitAnyLet": "off",
        "noArrayIndexKey": "off"
      },
      "a11y": {
        "useButtonType": "off",
        "useAltText": "off",
        "useSemanticElements": "off"
      },
      "performance": {
        "noDelete": "off"
      },
      "correctness": {
        "noSwitchDeclarations": "off"
      },
      "complexity": {
        "useLiteralKeys": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "files": {
    "includes": [
      "**/*.ts",
      "**/*.tsx",
      "!**/node_modules",
      "!**/node_modules",
      "!**/dist",
      "!**/dist",
      "!**/.next",
      "!**/.next",
      "!**/.turbo",
      "!**/.turbo",
      "!**/.vercel",
      "!**/.vercel",
      "!**/coverage",
      "!**/coverage",
      "!**/*.d.ts",
      "!**/*.js",
      "!**/*.jsx",
      "!**/*.mjs",
      "!**/*.cjs",
      "!**/pnpm-lock.yaml"
    ]
  }
}
