{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "useTemplate": "off",
        "noUnusedTemplateLiteral": "off",
        "useNodejsImportProtocol": "off"
      },
      "suspicious": {
        "noImplicitAnyLet": "off",
        "noArrayIndexKey": "off"
      },
      "a11y": {
        "useButtonType": "off",
        "useAltText": "off",
        "useSemanticElements": "off"
      },
      "performance": {
        "noDelete": "off"
      },
      "correctness": {
        "noSwitchDeclarations": "off"
      },
      "complexity": {
        "useLiteralKeys": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "files": {
    "include": ["**/*.ts", "**/*.tsx"],
    "ignore": ["node_modules", "dist", "*.d.ts", "*.js", "*.jsx", "*.mjs", "*.cjs", "pnpm-lock.yaml"]
  }
}
